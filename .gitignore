# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Local Claude Code state (agent worktrees, scratch); never part of the repo.
/.claude/

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
circuits_usb-*.tar

# Harness build products and fetched upstream sources.
harness/artifacts/
harness/modules/dummy_hcd/dummy_hcd.c
harness/tools/testusb/testusb.c
harness/raw_gadget/a3_device
harness/tools/testusb/testusb
# Kbuild leftovers for the out-of-tree dummy_hcd module.
harness/modules/dummy_hcd/*.o
harness/modules/dummy_hcd/*.ko
harness/modules/dummy_hcd/*.mod
harness/modules/dummy_hcd/*.mod.c
harness/modules/dummy_hcd/*.cmd
harness/modules/dummy_hcd/.*.cmd
harness/modules/dummy_hcd/Module.symvers
harness/modules/dummy_hcd/modules.order
harness/modules/dummy_hcd/.tmp_versions/

